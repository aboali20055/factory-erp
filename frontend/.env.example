# Frontend environment variables
# For local dev: copy to .env.local
# For Vercel production: set these in the Vercel dashboard → Project Settings → Environment Variables

# Your Railway backend URL (no trailing slash, no /api suffix)
# Dev:        http://localhost:3001
# Production: https://your-backend.up.railway.app
VITE_API_URL=https://your-backend.up.railway.app

VITE_APP_NAME=نظام إدارة المصنع
