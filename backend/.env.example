NODE_ENV=production
PORT=3001

# PostgreSQL — Railway provides DATABASE_URL automatically when you add a Postgres plugin
# Local:   postgresql://postgres:password@localhost:5432/factory_erp
# Railway: set in dashboard → Variables (Railway injects it automatically)
# Neon:    postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-hex-string"
JWT_EXPIRES_IN="7d"

# Your Vercel frontend URL — no trailing slash
CORS_ORIGIN="https://your-factory-erp.vercel.app"
